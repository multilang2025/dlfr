---
// Navigation reprise du site actuel delaguialuzon.fr
const nav = [
  { label: 'Domaines de compétences', href: '/domaines/' },
  { label: 'Qui sommes-nous ?', href: '/qui-sommes-nous/' },
  { label: 'Blog', href: '/blog/' }, // WordPress conservé
  { label: 'Contact', href: '/contact/' },
];
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label="Delaguía y Luzón — accueil">
      <img src="/assets/Logo-65_610.png" width="610" height="140" alt="Delaguía y Luzón" />
    </a>
    <nav aria-label="Navigation principale">
      <ul>
        {nav.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding-block: var(--space-2);
  }
  .brand {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
  }
  .brand img {
    height: 44px;
    width: auto;
    display: block;
  }
  nav ul {
    display: flex;
    gap: var(--space-3);
    list-style: none;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
  }
  nav a {
    color: var(--color-text);
    text-decoration: none;
    font-weight: 500;
  }
  nav a:hover {
    color: var(--color-accent-dark);
  }
</style>
