<section class="contact-band">
  <div class="container">
    <div class="cb-grid">
      <div class="cb-item">
        <span class="cb-ic"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2a7 7 0 0 0-7 7c0 5 7 13 7 13s7-8 7-13a7 7 0 0 0-7-7zm0 9.5A2.5 2.5 0 1 1 12 6.5a2.5 2.5 0 0 1 0 5z"/></svg></span>
        <div><p class="cb-h">Localisation :</p><p>15 Rue de la Montagne, Porte 1, 1er étage, 68100 Mulhouse</p></div>
      </div>
      <div class="cb-item">
        <span class="cb-ic"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20zm.5 5v5.2l4 2.4-1 1.6-5-3V7z"/></svg></span>
        <div><p class="cb-h">Heures d'ouverture :</p><p>Lundi – Jeudi : 08h30 – 18h00<br>Vendredi : 08h30 – 15h00</p></div>
      </div>
      <div class="cb-item">
        <span class="cb-ic"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 4h18a1 1 0 0 1 1 1v14a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1zm9 7 8-5V5l-8 5-8-5v1z"/></svg></span>
        <div><p class="cb-h">Email :</p><p><a href="mailto:felix.delaguia@delaguialuzon.fr">felix.delaguia@delaguialuzon.fr</a><br><a href="mailto:sonia.gomezluzon@delaguialuzon.fr">sonia.gomezluzon@delaguialuzon.fr</a></p></div>
      </div>
      <div class="cb-item">
        <span class="cb-ic"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6.6 2H4a2 2 0 0 0-2 2c0 9.4 7.6 17 17 17a2 2 0 0 0 2-2v-2.6a1 1 0 0 0-.8-1l-3.4-.7a1 1 0 0 0-1 .3l-1.3 1.3a14 14 0 0 1-6-6l1.3-1.3a1 1 0 0 0 .3-1L7.6 2.8a1 1 0 0 0-1-.8z"/></svg></span>
        <div><p class="cb-h">Téléphone :</p><p><a href="tel:+34963741657">+34 963 74 16 57</a></p></div>
      </div>
    </div>
    <div class="cb-socials">
      {socials.map((s) => (
        <a href={s.url} target="_blank" rel="noopener" aria-label={s.label}>
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d={s.d} /></svg>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .contact-band { background: var(--color-surface-cool); border-top: 1px solid var(--color-border); padding-block: var(--space-lg); }
  .cb-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-md); }
  .cb-item { display: flex; gap: 0.9rem; align-items: flex-start; }
  .cb-ic { flex: none; width: 44px; height: 44px; border-radius: 50%; background: #8a938b; color: #fff; display: flex; align-items: center; justify-content: center; }
  .cb-ic svg { width: 20px; height: 20px; fill: currentColor; }
  .cb-h { margin: 0 0 4px; font-weight: 700; color: var(--color-brand-heading); font-size: 16px; }
  .cb-item p { margin: 0; font-size: 15px; line-height: 1.55; color: var(--color-text); }
  .cb-item a { color: var(--color-text); }
  .cb-item a:hover { color: var(--color-link-hover); }
  .cb-socials { display: flex; gap: 0.9rem; margin-top: var(--space-md); }
  .cb-socials a { width: 46px; height: 46px; border-radius: 50%; background: var(--color-heading); color: #fff; display: flex; align-items: center; justify-content: center; transition: background var(--dur) var(--ease); }
  .cb-socials a:hover { background: var(--color-brand); }
  .cb-socials svg { width: 20px; height: 20px; fill: currentColor; }
  @media (max-width: 880px) { .cb-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 520px) { .cb-grid { grid-template-columns: 1fr; } }
</style>
