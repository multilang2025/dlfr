---
import Base from '../layouts/Base.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const CONTACT_URL = 'https://delaguialuzon.com/fr/';
---

<Base
  title="Contact — Delaguía y Luzón"
  description="Contactez le cabinet Delaguía y Luzón pour votre projet en Espagne. Réponse en français, anglais ou russe."
>
  <Breadcrumb items={[{ label: 'Contact' }]} />
  <section class="container intro">
    <h1>Contact</h1>
    <p class="lead">
      Pour toute demande, notre équipe vous répond en français, anglais ou russe.
    </p>
    <p>
      <a class="btn" href={CONTACT_URL}>Faire une demande</a>
    </p>
    <p class="note">
      Les demandes sont traitées via notre plateforme centralisée
      <a href={CONTACT_URL}>delaguialuzon.com</a>.
    </p>
    <address>
      Delaguía y Luzón — Mulhouse, France.
    </address>
  </section>
</Base>

<style>
  .intro { padding-block: var(--space-6); }
  .lead { font-size: 1.15rem; color: var(--color-muted); max-width: 60ch; }
  .btn {
    display: inline-block;
    margin-block: var(--space-2);
    padding: var(--space-1) var(--space-4);
    background: var(--color-accent);
    color: #fff;
    border-radius: var(--radius);
    text-decoration: none;
    font-weight: 600;
  }
  .btn:hover { background: var(--color-accent-dark); }
  .note { color: var(--color-muted); font-size: 0.95rem; }
  address { font-style: normal; margin-top: var(--space-3); }
</style>
