---
import Base from '../layouts/Base.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import data from '../data/legal/politique-de-confidentialite.json';
---

<Base
  title="Politique de confidentialité — Delaguía y Luzón"
  description="Politique de confidentialité du site Delaguía y Luzón."
>
  <Breadcrumb items={[{ label: 'Politique de confidentialité' }]} />
  <section class="legal">
    <div class="container">
      <h1>Politique de confidentialité</h1>
      <div class="prose" set:html={data.html}></div>
    </div>
  </section>
</Base>

<style>
  .legal { padding-block: var(--space-lg) var(--space-xl); }
  .legal .container { max-width: var(--content-width); }
  .prose :global(h2) { font-size: 1.4rem; color: var(--color-brand-heading); margin: 1.6em 0 .5em; }
  .prose :global(h3) { font-size: 1.15rem; color: var(--color-heading); font-weight: 600; margin: 1.4em 0 .4em; }
  .prose :global(p) { margin: 0 0 1em; line-height: 1.7; }
  .prose :global(ul) { margin: 0 0 1em; padding-left: 1.2em; line-height: 1.7; }
  .prose :global(a) { color: var(--color-link); }
</style>
