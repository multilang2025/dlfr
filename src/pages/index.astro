---
import Base from '../layouts/Base.astro';
import ContactCTA from '../components/ContactCTA.astro';

const CONTACT_URL = 'https://delaguialuzon.com/fr/';

// Grille des 9 domaines (réplique de la home actuelle) → liens vers la nouvelle structure en silo
const services = [
  { title: "Accompagnement à l'installation administrative", img: 'area-inmobiliario.jpg', href: '/domaines/s-installer-en-espagne/installation-administrative/' },
  { title: 'Conseil en droit fiscal et optimisation', img: 'area-mercantil.jpg', href: '/domaines/fiscalite/droit-fiscal-franco-espagnol/' },
  { title: "Création d'entreprise et choix de la structure juridique", img: 'area-sucesiones.jpg', href: '/domaines/entreprendre/creation-entreprise/' },
  { title: 'Droit du travail et recrutement', img: 'area-fiscal.jpg', href: '/domaines/emploi-rh/droit-du-travail/' },
  { title: 'Acquisition immobilière et droit de la propriété', img: 'area-laboral.jpg', href: '/domaines/immobilier/acquisition-immobiliere/' },
  { title: 'Droit des affaires et contrats commerciaux', img: 'area-extranjeria.jpg', href: '/domaines/entreprendre/droit-des-affaires/' },
  { title: 'Protection sociale et retraite', img: 'area-auditoria.jpg', href: '/domaines/s-installer-en-espagne/protection-sociale-retraite/' },
  { title: 'Accompagnement bancaire et financier', img: 'area-fiscalidad.jpg', href: '/domaines/s-installer-en-espagne/accompagnement-bancaire/' },
  { title: 'Médiation et résolution des litiges', img: 'area-social-corporativa.jpg', href: '/domaines/litiges/mediation-resolution/' },
];

// Articles (le blog reste sous WordPress) — liens vers les posts actuels
const articles = [
  { title: "Impatriés en Espagne : ce que le fisc attend que vous sachiez avant de rentrer", img: 'impatries-en-espagne.jpg', date: '25/05/2026', href: 'https://delaguialuzon.fr/impatries-en-espagne/' },
  { title: 'Expatriation en Espagne : les 9 pièges à éviter', img: 'expatriation-en-espagne.jpg', date: '20/05/2026', href: 'https://delaguialuzon.fr/expatriation-en-espagne/' },
  { title: 'Activités extrascolaires pour enfants à Valencia', img: 'activit-s-extrascolaires-enfants-valencia-1767192925105.png', date: '15/05/2026', href: 'https://delaguialuzon.fr/activites-extrascolaires-enfants-valencia/' },
];

const testimonials = [
  { name: 'STEPAHONE ANOUFA', role: 'Client Delaguía & Luzón', img: 'testimonio1-1.jpg', video: 'https://youtu.be/nQuYISPF9Es' },
  { name: 'RUBÉN DALVA', role: 'Délégué de la Chambre de commerce de Belgique et du Luxembourg', img: 'testimonio2.jpg', video: 'https://youtu.be/HWZ4_EgKh50' },
  { name: 'DOMINIQUE', role: 'Chasseur immobilier à Valence', img: 'testimonio3.jpg', video: 'https://youtu.be/ocOfoYCU790' },
];

const partners = [
  { name: 'Chambre française de Barcelone', img: 'Camara-Francesa-de-Barcelona-1-1.png' },
  { name: 'Ambassade de France en Espagne', img: 'Ambassade-de-France-en-Espagne-1-1.png' },
  { name: 'Chambre de commerce de Belgique et du Luxembourg en Espagne', img: 'Camara-de-Comercio-de-Belgica-y-Luxemburgo-en-Espana-1-1.png' },
];
---

<Base
  title="Delaguía y Luzón — Le trait d'union juridique entre la France et l'Espagne"
  description="Depuis 65 ans, Delaguía y Luzón accompagne particuliers et entreprises pour entreprendre, s'installer ou prendre leur retraite en Espagne : juridique, fiscal, administratif."
>
  <!-- HERO -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-text">
        <h1>Retraite au soleil, création d'entreprise ou ouverture de franchise : depuis 65 ans, Delaguía y Luzón est le trait d'union juridique entre la France et l'Espagne.</h1>
        <p class="lead">
          S'installer dans un nouveau pays est un défi. La barrière de la langue et les complexités
          administratives espagnoles ne doivent pas être un frein.
        </p>
        <ul class="usp">
          <li><strong>On parle votre langue :</strong> une équipe parfaitement francophone, pour des échanges clairs sans jargon.</li>
          <li><strong>On connaît le terrain :</strong> installés à Valence depuis 3 générations, nous maîtrisons les spécificités locales et nationales.</li>
          <li><strong>Guichet unique :</strong> du NIE à la signature chez le notaire, en passant par la création de vos statuts, nous gérons tout.</li>
        </ul>
        <a class="btn" href={CONTACT_URL}>Faire une demande</a>
      </div>
      <div class="hero-media">
        <img src="/assets/equipo.jpg" width="1100" height="506" alt="L'équipe du cabinet Delaguía y Luzón" />
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="stats">
    <div class="container stats-inner">
      <div><span class="num">65</span><span class="label">ans d'expérience</span></div>
      <div><span class="num">~25</span><span class="label">professionnels</span></div>
      <div><span class="num">3</span><span class="label">générations à Valence</span></div>
    </div>
  </section>

  <!-- INTRO ÉQUIPE -->
  <section class="container intro">
    <p>
      Notre bureau vise à offrir une solution globale et personnalisée aux entreprises et aux
      particuliers qui s'établissent ou investissent en Espagne, et plus particulièrement dans la
      Communauté valencienne. <strong>Notre équipe est notre force.</strong>
    </p>
  </section>

  <!-- DOMAINES / SERVICES -->
  <section class="services">
    <div class="container">
      <h2>Nous vous accompagnons dans votre projet en Espagne</h2>
      <ul class="grid-services">
        {services.map((s) => (
          <li>
            <a href={s.href}>
              <img src={`/assets/${s.img}`} width="321" height="321" alt={s.title} loading="lazy" />
              <h3>{s.title}</h3>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- POURQUOI NOUS CHOISIR -->
  <section class="why">
    <div class="container why-inner">
      <img class="why-photo" src="/assets/Felix-Delaguia-1.png" width="400" height="400" alt="Félix Delaguía, fondateur du cabinet" loading="lazy" />
      <div>
        <h2>Pourquoi choisir un cabinet franco-espagnol ?</h2>
        <ul class="usp">
          <li><strong>Double expertise :</strong> maîtrise des systèmes juridiques et fiscaux des deux pays.</li>
          <li><strong>Réseau local :</strong> partenariats avec des notaires, experts-comptables et avocats en Espagne.</li>
          <li><strong>Accompagnement sur mesure :</strong> adapté aux besoins des expatriés et des entrepreneurs.</li>
        </ul>
        <a class="btn-outline" href="/qui-sommes-nous/">Qui sommes-nous ?</a>
      </div>
    </div>
  </section>

  <!-- ARTICLES -->
  <section class="articles">
    <div class="container">
      <h2>Nos articles pour faciliter votre installation en Espagne</h2>
      <p class="section-lead">Notre bureau vous partage des informations précieuses en vue de votre installation en Espagne.</p>
      <ul class="grid-articles">
        {articles.map((a) => (
          <li>
            <a href={a.href}>
              <img src={`/assets/${a.img}`} alt={a.title} loading="lazy" />
              <span class="date">{a.date}</span>
              <h3>{a.title}</h3>
            </a>
          </li>
        ))}
      </ul>
      <p class="more-link"><a href="/blog/">Voir tous nos articles →</a></p>
    </div>
  </section>

  <!-- TÉMOIGNAGES -->
  <section class="testimonials">
    <div class="container">
      <h2>Témoignages de nos clients</h2>
      <p class="section-lead">
        La meilleure façon de nous connaître est d'écouter les retours réels des clients qui nous ont
        fait confiance.
      </p>
      <ul class="grid-testimonials">
        {testimonials.map((t) => (
          <li>
            <a href={t.video} target="_blank" rel="noopener" class="video" style={`background-image:url(/assets/${t.img})`} aria-label={`Voir le témoignage de ${t.name}`}>
              <span class="play" aria-hidden="true">▶</span>
            </a>
            <p class="name">{t.name}</p>
            <p class="role">{t.role}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- PARTENAIRES -->
  <section class="partners">
    <div class="container">
      <h2>Nos partenaires</h2>
      <ul class="grid-partners">
        {partners.map((p) => (
          <li><img src={`/assets/${p.img}`} alt={p.name} loading="lazy" /></li>
        ))}
      </ul>
    </div>
  </section>

  <ContactCTA />
</Base>

<style>
  h2 { font-size: clamp(1.5rem, 3vw, 2.2rem); }
  .btn, .btn-outline {
    display: inline-block;
    padding: var(--space-1) var(--space-4);
    border-radius: var(--radius);
    text-decoration: none;
    font-weight: 600;
  }
  .btn { background: var(--color-accent); color: #fff; }
  .btn:hover { background: var(--color-accent-dark); }
  .btn-outline { border: 2px solid var(--color-accent); color: var(--color-accent-dark); }
  .btn-outline:hover { background: var(--color-accent); color: #fff; }

  /* HERO */
  .hero { background: var(--color-surface); padding-block: var(--space-8); }
  .hero-inner { display: grid; grid-template-columns: 1.1fr 1fr; gap: var(--space-6); align-items: center; }
  .hero h1 { font-size: clamp(1.6rem, 2.6vw, 2.4rem); margin: 0 0 var(--space-2); }
  .hero .lead { font-size: 1.1rem; }
  .usp { list-style: none; padding: 0; margin: var(--space-2) 0; display: grid; gap: var(--space-1); }
  .usp li { padding-left: 1.4rem; position: relative; }
  .usp li::before { content: '✓'; position: absolute; left: 0; color: var(--color-accent); font-weight: 700; }
  .hero-media img { width: 100%; height: auto; border-radius: var(--radius); }

  /* STATS */
  .stats { background: var(--color-heading); color: #fff; }
  .stats-inner { display: flex; flex-wrap: wrap; justify-content: space-around; gap: var(--space-3); padding-block: var(--space-4); text-align: center; }
  .stats .num { display: block; font-size: 2.4rem; font-weight: 800; color: var(--color-accent); }
  .stats .label { color: #d7dae3; }

  .intro { padding-block: var(--space-6); max-width: 70ch; font-size: 1.1rem; }

  /* SERVICES */
  .services { padding-block: var(--space-4) var(--space-8); }
  .services h2 { text-align: center; margin-bottom: var(--space-4); }
  .grid-services { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-3); }
  .grid-services a { display: block; text-decoration: none; color: inherit; border: 1px solid var(--color-border); border-radius: var(--radius); overflow: hidden; background: #fff; transition: box-shadow 0.15s, transform 0.15s; }
  .grid-services a:hover { box-shadow: 0 8px 24px rgba(15,27,45,0.12); transform: translateY(-2px); }
  .grid-services img { width: 100%; height: 200px; object-fit: cover; display: block; }
  .grid-services h3 { font-size: 1.05rem; margin: 0; padding: var(--space-2); }

  /* WHY */
  .why { background: var(--color-surface); padding-block: var(--space-8); }
  .why-inner { display: grid; grid-template-columns: 320px 1fr; gap: var(--space-6); align-items: center; }
  .why-photo { width: 100%; height: auto; border-radius: var(--radius); }

  /* ARTICLES */
  .articles { padding-block: var(--space-8); }
  .articles h2, .testimonials h2, .partners h2 { text-align: center; }
  .section-lead { text-align: center; color: var(--color-muted); max-width: 60ch; margin: var(--space-1) auto var(--space-4); }
  .grid-articles { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-3); }
  .grid-articles a { display: block; text-decoration: none; color: inherit; border: 1px solid var(--color-border); border-radius: var(--radius); overflow: hidden; background: #fff; }
  .grid-articles a:hover { box-shadow: 0 8px 24px rgba(15,27,45,0.1); }
  .grid-articles img { width: 100%; height: 190px; object-fit: cover; display: block; }
  .grid-articles .date { display: block; padding: var(--space-1) var(--space-2) 0; color: var(--color-accent-dark); font-size: 0.85rem; }
  .grid-articles h3 { font-size: 1rem; margin: 0; padding: 0 var(--space-2) var(--space-2); }
  .more-link { text-align: center; margin-top: var(--space-4); }
  .more-link a { color: var(--color-accent-dark); font-weight: 600; }

  /* TESTIMONIALS */
  .testimonials { background: var(--color-surface); padding-block: var(--space-8); }
  .grid-testimonials { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-3); text-align: center; }
  .video { display: flex; align-items: center; justify-content: center; aspect-ratio: 16 / 10; background-size: cover; background-position: center; border-radius: var(--radius); }
  .video .play { width: 56px; height: 56px; border-radius: 50%; background: rgba(255,255,255,0.85); color: var(--color-heading); display: flex; align-items: center; justify-content: center; font-size: 1.3rem; }
  .video:hover .play { background: #fff; }
  .name { font-weight: 700; margin: var(--space-2) 0 0; }
  .role { color: var(--color-muted); margin: 0; font-size: 0.9rem; }

  /* PARTNERS */
  .partners { padding-block: var(--space-8); }
  .grid-partners { list-style: none; padding: 0; margin: var(--space-4) 0 0; display: flex; flex-wrap: wrap; justify-content: center; align-items: center; gap: var(--space-6); }
  .grid-partners img { max-height: 90px; width: auto; filter: grayscale(1); opacity: 0.8; transition: filter 0.2s, opacity 0.2s; }
  .grid-partners img:hover { filter: none; opacity: 1; }

  @media (max-width: 860px) {
    .hero-inner, .why-inner { grid-template-columns: 1fr; }
    .grid-services, .grid-articles, .grid-testimonials { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 560px) {
    .grid-services, .grid-articles, .grid-testimonials { grid-template-columns: 1fr; }
  }
</style>
