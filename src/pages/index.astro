---
import Base from '../layouts/Base.astro';
import SiloGrid from '../components/SiloGrid.astro';
import ContactCTA from '../components/ContactCTA.astro';
import { silos } from '../data/silos';

const CONTACT_URL = 'https://delaguialuzon.com/fr/';
const items = silos.map((s) => ({ title: s.title, intro: s.intro, href: `/domaines/${s.slug}/` }));
---

<Base
  title="Delaguía y Luzón — Entreprendre ou prendre sa retraite en Espagne"
  description="Cabinet d'accompagnement juridique, fiscal et administratif pour entreprendre ou prendre sa retraite en Espagne."
>
  <section class="hero">
    <div class="container">
      <h1>Entreprendre ou prendre sa retraite en Espagne</h1>
      <p class="lead">
        65 ans d'expérience, une équipe d'environ 25 professionnels à votre service.
      </p>
      <a class="btn" href={CONTACT_URL}>Faire une demande</a>
    </div>
  </section>

  <section class="container domaines">
    <h2>Nos domaines de compétences</h2>
    <SiloGrid items={items} />
  </section>

  <ContactCTA />
</Base>

<style>
  .hero {
    background: var(--color-surface);
    padding-block: var(--space-8);
  }
  .hero h1 {
    font-size: clamp(1.8rem, 4vw, 3rem);
    margin: 0 0 var(--space-2);
  }
  .lead {
    font-size: 1.2rem;
    color: var(--color-muted);
    max-width: 40ch;
  }
  .btn {
    display: inline-block;
    margin-top: var(--space-3);
    padding: var(--space-1) var(--space-4);
    background: var(--color-accent);
    color: #fff;
    border-radius: var(--radius);
    text-decoration: none;
    font-weight: 600;
  }
  .btn:hover {
    background: var(--color-accent-dark);
  }
  .domaines {
    padding-block: var(--space-6);
  }
  .domaines h2 {
    margin-bottom: var(--space-3);
  }
</style>
