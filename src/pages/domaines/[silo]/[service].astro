---
import Base from '../../../layouts/Base.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import Reviews from '../../../components/Reviews.astro';
import { silos } from '../../../data/silos';

export function getStaticPaths() {
  return silos.flatMap((s) =>
    s.subservices.map((ss) => ({
      params: { silo: s.slug, service: ss.slug },
      props: { silo: s, service: ss },
    }))
  );
}

const { silo, service } = Astro.props;
const siblings = silo.subservices.filter((ss) => ss.slug !== service.slug);

// Contenu riche par slug (src/data/services/<slug>.json), si présent.
const modules = import.meta.glob('../../../data/services/*.json', { eager: true });
let content: any = null;
for (const path in modules) {
  if (path.endsWith(`/${service.slug}.json`)) { content = (modules[path] as any).default ?? modules[path]; break; }
}
const CONTACT = 'https://delaguialuzon.com/fr/';
const heroImg = content?.heroImage ?? service.img;
const tilts = [-3, 2.4, -2.2, 2.8, -2.6, 2];
---

<Base title={`${service.title} — Delaguía y Luzón`} description={content?.heroSub ?? service.intro}>
  <Breadcrumb items={[
    { label: 'Domaines de compétences', href: '/domaines/' },
    { label: silo.title, href: `/domaines/${silo.slug}/` },
    { label: service.title },
  ]} />

  <section class="hero">
    <div class="container hero-grid">
      <div>
        <h1>{service.title}</h1>
        <p class="hero-sub" set:html={content?.heroSub ?? service.intro}></p>
        {content?.heroNote && <p class="hero-note" set:html={content.heroNote}></p>}
        <a class="btn" href={CONTACT}>Faire une demande</a>
      </div>
      <img src={`/assets/${heroImg}`} alt={service.title} />
    </div>
  </section>

  {content?.sections?.map((sec: any) => (
    <section class:list={["acc", { alt: sec.alt }]}>
      <div class:list={["container", "acc-grid", { rev: sec.rev }]}>
        <div class="acc-text">
          <h2 set:html={sec.heading}></h2>
          {sec.body?.map((p: string) => <p set:html={p} />)}
          {sec.bullets && sec.bullets.length > 0 && (
            <ul>{sec.bullets.map((b: string) => <li set:html={b} />)}</ul>
          )}
        </div>
        <div class="acc-media"><img src={`/assets/${sec.image}`} alt={sec.heading} loading="lazy" /></div>
      </div>
    </section>
  ))}

  {content?.testimonial && (
    <section class="tband">
      <div class="container tband-in">
        <a class="t-media" href={content.testimonial.video} target="_blank" rel="noopener" style={`background-image:url(/assets/${content.testimonial.img})`} aria-label={`Voir le témoignage de ${content.testimonial.name}`}><span class="play" aria-hidden="true">▶</span></a>
        <div>
          <p class="t-eyebrow">Témoignage client</p>
          <h2>Ils nous font confiance</h2>
          <p class="t-name" set:html={content.testimonial.name}></p>
          <p class="t-role" set:html={content.testimonial.role}></p>
          <a class="t-link" href={content.testimonial.video} target="_blank" rel="noopener">Voir le témoignage en vidéo →</a>
        </div>
      </div>
    </section>
  )}

  {content?.faq && content.faq.length > 0 && (
    <section class="faq">
      <div class="container">
        <div class="faq-head">
          <h2>Questions fréquentes</h2>
          <p class="faq-sub">Vos questions les plus courantes sur « {service.title} ».</p>
        </div>
        <div class="faq-deck">
          {content.faq.map((f: any, i: number) => (
            <div class="faq-item" style={`transform:rotate(${tilts[i % tilts.length]}deg)`}>
              <button class="faq-q" type="button"><span set:html={f.q}></span><span class="ic" aria-hidden="true">+</span></button>
              <div class="faq-a"><p set:html={f.a} /></div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {!content && (
    <section class="container placeholder-note">
      <p>Contenu détaillé en cours d'intégration depuis le site actuel.</p>
    </section>
  )}

  {siblings.length > 0 && (
    <section class="related">
      <div class="container">
        <h2>Dans le même domaine : {silo.title}</h2>
        <div class="rel-grid">
          {siblings.map((ss) => (
            <a class="rel-card" href={`/domaines/${silo.slug}/${ss.slug}/`}>
              <div class="rc-img"><img src={`/assets/${ss.img}`} alt={ss.title} loading="lazy" /></div>
              <div class="rc-body"><h3>{ss.title}</h3><span class="rc-link">En savoir plus →</span></div>
            </a>
          ))}
        </div>
        <p class="back"><a href="/domaines/">← Voir tous nos domaines de compétences</a></p>
      </div>
    </section>
  )}

  <Reviews />

  <section class="svc-cta">
    <div class="container">
      <p class="cta-eyebrow">Vous avez une question ?</p>
      <h2>Une question, un projet en Espagne ?</h2>
      <p>Faites votre demande : notre équipe vous répond en français, anglais ou russe.</p>
      <a class="btn" href={CONTACT}>Faire une demande</a>
    </div>
  </section>
</Base>

<style>
  .btn { display: inline-block; background: var(--color-btn); color: #fff; font-weight: 600; padding: 13px 28px; border-radius: var(--radius-md); text-decoration: none; }
  .btn:hover { background: var(--color-btn-hover); color: #fff; }

  /* HERO */
  .hero { background: var(--color-surface); padding-block: var(--space-xl); }
  .hero-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-lg); align-items: center; }
  .hero h1 { margin: 0 0 12px; }
  .hero-sub { font-size: clamp(1.1rem, 2vw, 1.5rem); line-height: 1.3; margin: 0 0 14px; font-family: var(--font-heading); color: var(--color-brand-heading); font-weight: 300; }
  .hero-note { font-size: 16px; line-height: 1.6; color: var(--color-muted); margin: 0 0 24px; max-width: 46ch; }
  .hero img { width: 100%; height: 100%; object-fit: cover; border-radius: var(--radius-md); display: block; min-height: 320px; }

  /* CONTENT SECTIONS */
  .acc { padding-block: var(--space-xl); }
  .acc-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-lg); align-items: center; }
  .acc-grid.rev .acc-media { order: -1; }
  .acc.alt { background: var(--color-surface); }
  .acc h2 { margin: 0 0 16px; }
  .acc p { font-size: 16px; line-height: 1.7; color: var(--color-text); margin: 0 0 0.75rem; }
  .acc ul { list-style: none; padding: 0; margin: 24px 0 0; display: grid; gap: 12px; }
  .acc li { position: relative; padding-left: 28px; font-size: 16px; line-height: 1.5; }
  .acc li::before { content: '✓'; position: absolute; left: 0; color: var(--color-brand); font-weight: 700; }
  .acc-media img { width: 100%; height: 100%; object-fit: cover; border-radius: var(--radius-md); display: block; min-height: 360px; }

  /* TESTIMONIAL */
  .tband { padding-block: var(--space-xl); background: var(--color-surface); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); }
  .tband-in { display: grid; grid-template-columns: 440px 1fr; gap: 48px; align-items: center; }
  .t-media { display: flex; align-items: center; justify-content: center; aspect-ratio: 16/10; background-size: cover; background-position: center; border-radius: var(--radius-md); }
  .t-media .play { width: 64px; height: 64px; border-radius: 50%; background: rgba(255,255,255,.85); color: var(--color-heading); display: flex; align-items: center; justify-content: center; font-size: 20px; padding-left: 4px; }
  .t-media:hover .play { background: #fff; }
  .t-eyebrow { text-transform: uppercase; letter-spacing: .08em; font-size: 13px; font-weight: 700; color: var(--color-brand); margin: 0 0 8px; }
  .tband h2 { margin: 0 0 16px; }
  .t-name { font-weight: 700; letter-spacing: .03em; color: var(--color-text-strong); margin: 0; }
  .t-role { color: var(--color-muted); margin: 2px 0 16px; font-size: 15px; }
  .t-link { color: var(--color-brand-heading); font-weight: 600; }

  /* FAQ */
  .faq { padding-block: var(--space-xl); background: var(--color-surface-cool); border-top: 1px solid var(--color-border); }
  .faq-head { text-align: center; margin-bottom: 44px; }
  .faq-head h2 { margin: 0; }
  .faq-sub { margin: 12px 0 0; color: var(--color-muted); font-size: var(--fs-lead); }
  .faq-deck { max-width: 820px; margin: 0 auto; padding: 24px 0 12px; }
  .faq-item { background: #fff; border: 1px solid var(--color-border); border-radius: var(--radius-md); margin: 4px 0; box-shadow: var(--shadow-sm); transform-origin: center center; transition: transform .4s var(--ease), box-shadow .3s var(--ease), margin .4s var(--ease); }
  .faq-item:hover { transform: rotate(0) scale(1.015) !important; box-shadow: var(--shadow-md); position: relative; z-index: 3; }
  .faq-item.open { transform: rotate(0) !important; box-shadow: var(--shadow-md); margin: 18px 0; position: relative; z-index: 2; }
  .faq-q { width: 100%; display: flex; justify-content: space-between; align-items: center; gap: 16px; background: none; border: 0; cursor: pointer; padding: 20px 24px; font-family: var(--font-heading); font-weight: 700; font-size: 18px; color: var(--color-heading); text-align: left; }
  .faq-q .ic { flex: none; color: var(--color-brand); font-size: 22px; line-height: 1; transition: transform .3s var(--ease); }
  .faq-item.open .faq-q .ic { transform: rotate(45deg); }
  .faq-a { max-height: 0; overflow: hidden; transition: max-height .4s var(--ease); }
  .faq-a p { margin: 0; padding: 0 24px 22px; color: var(--color-text); font-size: 16px; line-height: 1.65; }

  /* RELATED */
  .related { padding-block: var(--space-lg); border-top: 1px solid var(--color-border); background: #fff; }
  .related h2 { font-size: 28px; margin: 0 0 24px; }
  .rel-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 24px; margin-bottom: 24px; }
  .rel-card { display: block; text-decoration: none; color: inherit; border: 1px solid var(--color-border); border-radius: var(--radius-md); overflow: hidden; background: #fff; transition: box-shadow .2s var(--ease), transform .2s var(--ease); }
  .rel-card:hover { box-shadow: var(--shadow-md); transform: translateY(-3px); }
  .rc-img { height: 158px; overflow: hidden; }
  .rc-img img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .45s var(--ease); }
  .rel-card:hover .rc-img img { transform: scale(1.06); }
  .rc-body { padding: 18px 20px 20px; }
  .rc-body h3 { font-size: 18px; line-height: 1.3; margin: 0 0 10px; color: var(--color-brand-heading); font-weight: 300; }
  .rc-link { color: var(--color-brand-heading); font-weight: 600; font-size: 14px; }
  .back a { color: var(--color-brand-heading); font-weight: 600; }

  .placeholder-note { padding-block: var(--space-lg); color: var(--color-muted); font-style: italic; }

  /* CTA (sombre) */
  .svc-cta { background: var(--color-heading); text-align: center; padding-block: var(--space-lg); }
  .svc-cta .cta-eyebrow { text-transform: uppercase; letter-spacing: .12em; font-size: 13px; font-weight: 700; color: var(--color-brand); margin: 0 0 8px; }
  .svc-cta h2 { color: #fff; margin: 0 0 8px; }
  .svc-cta p { color: var(--color-on-dark); margin: 0 0 24px; }

  @media (max-width: 880px) {
    .hero-grid, .acc-grid, .tband-in { grid-template-columns: 1fr; }
    .hero img, .acc-media img { min-height: 240px; }
  }
</style>

<script>
  document.querySelectorAll('.faq-item').forEach((it) => {
    const q = it.querySelector('.faq-q');
    const a = it.querySelector('.faq-a') as HTMLElement;
    q?.addEventListener('click', () => {
      const open = it.classList.toggle('open');
      a.style.maxHeight = open ? a.scrollHeight + 'px' : '0px';
    });
  });
</script>
