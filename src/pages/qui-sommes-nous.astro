---
import Base from '../layouts/Base.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
---

<Base
  title="Qui sommes-nous ? — Delaguía y Luzón"
  description="Cabinet franco-espagnol fort de 65 ans d'expérience et d'une équipe d'environ 25 professionnels au service de votre projet en Espagne."
>
  <Breadcrumb items={[{ label: 'Qui sommes-nous ?' }]} />
  <section class="about">
    <div class="container">
      <p class="eyebrow">Le cabinet</p>
      <h1>Qui sommes-nous ?</h1>
      <p class="lead">
        65 ans d'expérience, une équipe d'environ 25 professionnels au service de votre projet en Espagne.
      </p>
      <img class="hero-img" src="/assets/equipo.jpg" width="1100" height="506" alt="L'équipe du cabinet Delaguía y Luzón" fetchpriority="high" decoding="async" />
      <p class="body">
        Installés à Valence depuis trois générations, nous accompagnons particuliers et entreprises
        francophones dans toutes leurs démarches juridiques, fiscales et administratives entre la France
        et l'Espagne. <strong>Notre équipe est notre force.</strong>
      </p>
    </div>
  </section>
</Base>

<style>
  .about { padding-block: var(--space-lg) var(--space-xl); }
  .about .container { max-width: var(--content-width); }
  .eyebrow { text-transform: uppercase; letter-spacing: .12em; font-size: 13px; font-weight: 700; color: var(--color-brand); margin: 0 0 10px; }
  .about h1 { margin: 0 0 12px; }
  .lead { font-size: var(--fs-lead); color: var(--color-muted); max-width: 60ch; margin: 0; }
  .hero-img { width: 100%; height: auto; border-radius: var(--radius-md); margin: 24px 0; display: block; }
  .body { font-size: 16px; line-height: 1.6; }
</style>
