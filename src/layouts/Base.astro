---
// Polices : Rotis (titres, @font-face dans tokens.css) + pile système (corps) — design .com
import '../styles/tokens.css';
import Header from '../components/Header.astro';
import ContactBand from '../components/ContactBand.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = '' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;

// JSON-LD — entité du cabinet (présent sur toutes les pages)
const org = {
  '@context': 'https://schema.org',
  '@type': 'LegalService',
  name: 'Delaguía y Luzón',
  legalName: 'Delaguía-Luzón Abogados y Asesores Tributarios, S.L.P.',
  description:
    "Cabinet franco-espagnol d'accompagnement juridique, fiscal et administratif pour entreprendre, s'installer ou prendre sa retraite en Espagne.",
  url: 'https://delaguialuzon.fr',
  image: 'https://delaguialuzon.fr/assets/Logo-65_610.png',
  telephone: '+34963741657',
  email: 'felix.delaguia@delaguialuzon.fr',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '15 Rue de la Montagne, Porte 1, 1er étage',
    postalCode: '68100',
    addressLocality: 'Mulhouse',
    addressCountry: 'FR',
  },
  areaServed: ['ES', 'FR'],
  availableLanguage: ['fr', 'en', 'ru'],
  sameAs: [
    'https://www.facebook.com/DelaguiaLuzon/',
    'https://www.linkedin.com/company/delaguia-luzon/',
    'https://www.youtube.com/channel/UC4xGIk_KROr6k4t73SGN7ZA',
    'https://www.instagram.com/delaguialuzon/',
  ],
};
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <script type="application/ld+json" is:inline set:html={JSON.stringify(org)} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <ContactBand />
    <Footer />
    <div id="vlb" class="vlb" hidden>
      <button class="vlb-close" type="button" aria-label="Fermer la vidéo">✕</button>
      <div class="vlb-frame"></div>
    </div>
  </body>
</html>

<style>
  .vlb { position: fixed; inset: 0; z-index: 1000; display: flex; align-items: center; justify-content: center; padding: 24px; background: rgba(20, 24, 28, 0.82); }
  .vlb[hidden] { display: none; }
  .vlb-frame { position: relative; width: min(100%, 960px); aspect-ratio: 16 / 9; border-radius: var(--radius-md); overflow: hidden; box-shadow: var(--shadow-md); background: #000; }
  .vlb-frame :global(iframe) { width: 100%; height: 100%; border: 0; display: block; }
  .vlb-close { position: absolute; top: 18px; right: 18px; width: 44px; height: 44px; border-radius: 50%; border: 0; cursor: pointer; background: #fff; color: var(--color-heading); font-size: 20px; line-height: 1; display: flex; align-items: center; justify-content: center; box-shadow: var(--shadow-sm); }
  .vlb-close:hover { background: var(--color-surface); }
</style>

<script>
  const vlb = document.getElementById('vlb');
  if (vlb) {
    const frame = vlb.querySelector('.vlb-frame');
    const ytId = (url: string) => {
      const m = url.match(/(?:youtu\.be\/|[?&]v=|embed\/)([\w-]{6,})/);
      return m ? m[1] : null;
    };
    const open = (url: string) => {
      const id = ytId(url);
      if (!id || !frame) return;
      frame.innerHTML = '<iframe src="https://www.youtube-nocookie.com/embed/' + id + '?autoplay=1&rel=0" title="Vidéo" allow="autoplay; encrypted-media; fullscreen" allowfullscreen></iframe>';
      vlb.hidden = false;
      document.body.style.overflow = 'hidden';
    };
    const close = () => {
      vlb.hidden = true;
      if (frame) frame.innerHTML = '';
      document.body.style.overflow = '';
    };
    document.addEventListener('click', (e) => {
      const a = (e.target as HTMLElement).closest('a.video-link') as HTMLAnchorElement | null;
      if (a) { e.preventDefault(); open(a.getAttribute('href') || ''); }
    });
    vlb.querySelector('.vlb-close')?.addEventListener('click', close);
    vlb.addEventListener('click', (e) => { if (e.target === vlb) close(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !vlb.hidden) close(); });
  }
</script>
