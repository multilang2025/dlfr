# Force index.html comme page d'accueil par défaut.
# Évite que la page placeholder de Hostinger (default.php / index.php) masque le site.
DirectoryIndex index.html index.htm

# Petits réglages utiles
Options -Indexes

# --- Redirections 301 : anciennes URLs WordPress -> nouvelle structure en silo ---
# S'appliquent en production sur delaguialuzon.fr (inertes sur la préprod).
# NB : /blog/ reste géré par WordPress et n'est jamais redirigé ici.
RedirectMatch 301 ^/domaines-expertise/?$ /domaines/
RedirectMatch 301 ^/installation-administrative-espagne/?$ /domaines/s-installer-en-espagne/installation-administrative/
RedirectMatch 301 ^/protection-sociale-et-retraite-en-espagne/?$ /domaines/s-installer-en-espagne/protection-sociale-retraite/
RedirectMatch 301 ^/accompagnement-bancaire-et-financier-en-espagne/?$ /domaines/s-installer-en-espagne/accompagnement-bancaire/
RedirectMatch 301 ^/droit-fiscal-espagnol/?$ /domaines/fiscalite/droit-fiscal-franco-espagnol/
RedirectMatch 301 ^/services-conseils-fiscaux/?$ /domaines/fiscalite/conseils-fiscaux-valencia/
RedirectMatch 301 ^/creation-entreprise-espagne/?$ /domaines/entreprendre/creation-entreprise/
RedirectMatch 301 ^/droit-des-affaires-espagne/?$ /domaines/entreprendre/droit-des-affaires/
RedirectMatch 301 ^/droit-commercial/?$ /domaines/entreprendre/droit-commercial/
RedirectMatch 301 ^/droit-du-travail-et-recrutement-en-espagne/?$ /domaines/emploi-rh/droit-du-travail/
RedirectMatch 301 ^/conseil-en-ressources-humaines/?$ /domaines/emploi-rh/ressources-humaines/
RedirectMatch 301 ^/compliance-du-travail/?$ /domaines/emploi-rh/compliance-du-travail/
RedirectMatch 301 ^/acquisition-immobiliere-espagne/?$ /domaines/immobilier/acquisition-immobiliere/
RedirectMatch 301 ^/resolution-de-litiges-espagne/?$ /domaines/litiges/mediation-resolution/
RedirectMatch 301 ^/cabinet-avocat-espagne/?$ /qui-sommes-nous/

# --- Performance : compression du texte (gzip) ---
# Réduit le poids transféré du HTML/CSS/JS/SVG (Core Web Vitals : LCP).
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml application/xml
  AddOutputFilterByType DEFLATE application/rss+xml application/atom+xml
  AddOutputFilterByType DEFLATE font/woff font/woff2 application/font-woff
</IfModule>

# --- Performance : cache navigateur des ressources statiques ---
# Assets (images, polices, CSS/JS) : cache long. HTML : revalidation rapide
# pour refléter les mises à jour sans servir une page périmée.
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html                 "access plus 0 seconds"
  ExpiresByType text/css                  "access plus 1 year"
  ExpiresByType application/javascript    "access plus 1 year"
  ExpiresByType image/jpeg                "access plus 1 year"
  ExpiresByType image/png                 "access plus 1 year"
  ExpiresByType image/webp                "access plus 1 year"
  ExpiresByType image/svg+xml             "access plus 1 year"
  ExpiresByType image/x-icon              "access plus 1 year"
  ExpiresByType font/woff                 "access plus 1 year"
  ExpiresByType font/woff2                "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|jpg|jpeg|png|webp|svg|ico|woff|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>
