# Modèle — copier ce fichier en `.env` puis remplir avec tes vraies valeurs.
# Le fichier `.env` est gitignoré : il ne sera JAMAIS commité.
# Ces mêmes valeurs devront aussi être enregistrées dans GitHub Secrets
# (Settings → Secrets and variables → Actions) pour le déploiement automatique.

# Hôte FTP fourni par Hostinger (ex : ftp.delaguialuzon.fr ou 12.34.56.78)
FTP_SERVER=

# Identifiant FTP
FTP_USERNAME=

# Mot de passe FTP
FTP_PASSWORD=

# Port (Hostinger : 21 en FTP, ou 22 si SFTP)
FTP_PORT=21

# Dossier cible sur le serveur (racine du site)
FTP_SERVER_DIR=/public_html/
